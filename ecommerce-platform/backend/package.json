  "description": "Backend E-commerce con Node.js, Express, TypeScript y PostgreSQL",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
